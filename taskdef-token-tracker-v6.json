{
    "family":  "jarvis-pilot-token-tracker",
    "taskRoleArn":  "arn:aws-us-gov:iam::660264611488:role/jarvis-pilot-openwebui-task-role",
    "executionRoleArn":  "arn:aws-us-gov:iam::660264611488:role/jarvis-pilot-openwebui-execution-role",
    "networkMode":  "awsvpc",
    "containerDefinitions":  [
                                 {
                                     "name":  "token-tracker",
                                     "image":  "660264611488.dkr.ecr.us-gov-west-1.amazonaws.com/jarvis-token-tracker:pilot-20260629-004",
                                     "cpu":  0,
                                     "portMappings":  [
                                                          {
                                                              "containerPort":  8080,
                                                              "hostPort":  8080,
                                                              "protocol":  "tcp"
                                                          }
                                                      ],
                                     "essential":  true,
                                     "environment":  [
                                                         {
                                                             "name":  "Polling__IntervalMinutes",
                                                             "value":  "15"
                                                         },
                                                         {
                                                             "name":  "Providers__Gateway__BaseUrl",
                                                             "value":  "https://jarvis-ai-gateway.aigov.keysight.com/"
                                                         },
                                                         {
                                                             "name":  "ASPNETCORE_ENVIRONMENT",
                                                             "value":  "Development"
                                                         },
                                                         {
                                                             "name":  "Polling__Enabled",
                                                             "value":  "true"
                                                         },
                                                         {
                                                             "name":  "Providers__AwsBedrock__Enabled",
                                                             "value":  "false"
                                                         },
                                                         {
                                                             "name":  "ASPNETCORE_URLS",
                                                             "value":  "http://0.0.0.0:8080"
                                                         },
                                                         {
                                                             "name":  "Providers__Mock__Enabled",
                                                             "value":  "false"
                                                         },
                                                         {
                                                             "name":  "Providers__GoogleVertex__Enabled",
                                                             "value":  "false"
                                                         },
                                                         {
                                                             "name":  "Providers__AzureOpenAi__Enabled",
                                                             "value":  "false"
                                                         },
                                                         {
                                                             "name":  "ConnectionStrings__UsageDashboard",
                                                             "value":  "Data Source=/tmp/usage-dashboard.db"
                                                         },
                                                         {
                                                             "name":  "Providers__Gateway__Enabled",
                                                             "value":  "true"
                                                         },
                                                         {
                                                             "name":  "Polling__LookbackMinutes",
                                                             "value":  "60"
                                                         }
                                                     ],
                                     "mountPoints":  [

                                                     ],
                                     "volumesFrom":  [

                                                     ],
                                     "logConfiguration":  {
                                                              "logDriver":  "awslogs",
                                                              "options":  {
                                                                              "awslogs-group":  "/jarvis/token-tracker",
                                                                              "awslogs-region":  "us-gov-west-1",
                                                                              "awslogs-stream-prefix":  "ecs"
                                                                          }
                                                          },
                                     "systemControls":  [

                                                        ]
                                 }
                             ],
    "requiresCompatibilities":  [
                                    "FARGATE"
                                ],
    "cpu":  "512",
    "memory":  "1024"
}