@page "/"
@rendermode InteractiveServer
@using AiUsageDashboard.Contracts
@using AiUsageDashboard.Storage
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = "Admin")]
@inject IDashboardQueryService Dashboard

<PageTitle>Jarvis Usage Command Center</PageTitle>

<section class="hero">
    <div>
        <p class="eyebrow">GovCloud-ready AI observability</p>
        <h1>Jarvis Usage Command Center</h1>
        <p class="subtitle">Approved model usage meters, quota utilization, and estimated spend across operational gateway and cloud-provider telemetry.</p>
    </div>
    <div class="actions">
        <label>From <InputDate @bind-Value="_fromDate" /></label>
        <label>To <InputDate @bind-Value="_toDate" /></label>
        <button class="refresh" @onclick="LoadAsync">Refresh telemetry</button>
        <a class="refresh link" href="@ExportUrl">Export CSV</a>
    </div>
</section>

@if (_loading)
{
    <div class="loading">Loading usage telemetry…</div>
}
else
{
    <section class="cards">
        <article class="metric">
            <span>Estimated cost</span>
            <strong>@_data.Summary.EstimatedCostUsd.ToString("C")</strong>
            <small>Only shown when pricing exists</small>
        </article>
        <article class="metric">
            <span>Total tokens</span>
            <strong>@Format(_data.Summary.TotalTokens)</strong>
            <small>Input + output + cached compatibility view</small>
        </article>
        <article class="metric">
            <span>Total requests</span>
            <strong>@_data.Summary.TotalRequests.ToString("N0")</strong>
            <small>Metadata-only gateway calls</small>
        </article>
        <article class="metric">
            <span>Unpriced meters</span>
            <strong>@UnpricedMeterCount</strong>
            <small>Unknown or missing pricing</small>
        </article>
    </section>

    <section class="grid">
        <article class="panel wide">
            <div class="panel-title">
                <h2>Cost over time</h2>
                <span>Meter-priced usage only</span>
            </div>
            <div class="line-chart">
                @foreach (var point in CostSeries)
                {
                    <div class="line-point" style="height:@ChartHeight(point.CostUsd)">
                        <span>@point.CostUsd.ToString("C")</span>
                        <small>@point.Date.ToString("MM-dd")</small>
                    </div>
                }
            </div>
        </article>

        <article class="panel">
            <div class="panel-title">
                <h2>Provider split</h2>
                <span>Estimated cost</span>
            </div>
            <div class="legend">
                @foreach (var item in _data.Summary.CostByProvider)
                {
                    <div><span></span>@item.Key <b>@item.Value.ToString("C")</b></div>
                }
            </div>
        </article>
    </section>

    <section class="panel table-panel">
        <div class="panel-title">
            <h2>Usage by meter kind</h2>
            <span>Meter-based usage, including unknowns</span>
        </div>
        <div class="bars">
            @foreach (var meter in UsageByMeterRows)
            {
                <div class="bar-row">
                    <label>@meter.Key @MeterBadge(meter.Key)</label>
                    <div class="bar-track"><div class="bar-input" style="width:@Percent(meter.Value, MaxMeterQuantity)"></div></div>
                    <span>@FormatDecimal(meter.Value)</span>
                </div>
            }
        </div>
    </section>

    <section class="panel table-panel">
        <div class="panel-title">
            <h2>Approved model usage</h2>
            <span>Prompts/source text are never stored</span>
        </div>
        <table>
            <thead><tr><th>Provider</th><th>Region</th><th>Model</th><th>Meters</th><th>Requests</th><th>Quota util.</th><th>Est. cost</th><th>Badges</th></tr></thead>
            <tbody>
                @foreach (var row in _data.Records)
                {
                    <tr>
                        <td><span class="pill">@row.Provider</span></td>
                        <td>@row.Region</td>
                        <td>@row.ModelAlias</td>
                        <td>@MeterList(row)</td>
                        <td>@row.Requests.ToString("N0")</td>
                        <td>@QuotaUtilization(row)</td>
                        <td>@(row.EstimatedCostUsd?.ToString("C") ?? "Unpriced")</td>
                        <td>@Badges(row)</td>
                    </tr>
                }
            </tbody>
        </table>
    </section>
}

@code {
    private bool _loading = true;
    private DateTime _fromDate = DateTime.UtcNow.AddDays(-30).Date;
    private DateTime _toDate = DateTime.UtcNow.Date.AddDays(1);
    private DashboardData _data = new(new DashboardSummary(0, 0, 0, new Dictionary<string, decimal>(), new Dictionary<string, decimal>(), new Dictionary<UsageMeterKind, decimal>(), new Dictionary<string, decimal>()), [], [], []);

    private string ExportUrl => $"/admin/export.csv?from={Uri.EscapeDataString(From.ToString("O"))}&to={Uri.EscapeDataString(To.ToString("O"))}";
    private DateTimeOffset From => new(_fromDate, TimeSpan.Zero);
    private DateTimeOffset To => new(_toDate, TimeSpan.Zero);
    private IReadOnlyDictionary<UsageMeterKind, decimal> UsageByMeter => _data.Summary.UsageByMeter ?? new Dictionary<UsageMeterKind, decimal>();
    private IReadOnlyList<KeyValuePair<UsageMeterKind, decimal>> UsageByMeterRows => UsageByMeter.ToArray();
    private IReadOnlyList<TimeSeriesPoint> CostSeries => _data.CostOverTime.Count == 0 ? [new TimeSeriesPoint(DateOnly.FromDateTime(DateTime.UtcNow), 0, 0, 0, null)] : _data.CostOverTime;
    private decimal MaxMeterQuantity => Math.Max(1, UsageByMeter.Values.DefaultIfEmpty(1).Max());
    private int UnpricedMeterCount => _data.Records.Count(x => x.HasUnpricedMeters);

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _data = await Dashboard.GetDashboardAsync(From, To, CancellationToken.None);
        _loading = false;
    }

    private string ChartHeight(decimal value)
    {
        var max = Math.Max(1, _data.CostOverTime.Count == 0 ? 1 : _data.CostOverTime.Max(x => x.CostUsd));
        return $"{Math.Max(12, value / max * 140):0}px";
    }

    private static string Percent(decimal value, decimal total) => $"{Math.Round(value * 100m / total, 2)}%";
    private static string Format(long value) => value >= 1_000_000 ? $"{value / 1_000_000m:N1}M" : value.ToString("N0");
    private static string FormatDecimal(decimal value) => value >= 1_000_000 ? $"{value / 1_000_000m:N1}M" : value.ToString("N2");
    private static string MeterBadge(UsageMeterKind kind) => kind == UsageMeterKind.Unknown ? "⚠ unknown" : string.Empty;
    private static string MeterList(AiUsageRecord row) => string.Join("; ", row.Metrics.Select(m => $"{m.Kind}: {FormatDecimal(m.Quantity)} {m.Unit}"));
    private static string Badges(AiUsageRecord row) => string.Join(" ", new[] { row.HasUnknownMeters ? "Unknown" : string.Empty, row.HasUnpricedMeters ? "Unpriced" : string.Empty }.Where(x => !string.IsNullOrWhiteSpace(x)));

    private string QuotaUtilization(AiUsageRecord row)
    {
        var matches = _data.Quotas.Where(q => q.Provider == row.Provider && q.Region == row.Region && q.ModelId == row.ModelId).ToArray();
        if (matches.Length == 0)
        {
            return "—";
        }

        return string.Join("; ", matches.Select(q => $"{q.MeterKind}: {Percent(row.Metrics.Where(m => m.Kind == q.MeterKind).Sum(m => m.Quantity), Math.Max(1, q.Limit))}"));
    }
}
